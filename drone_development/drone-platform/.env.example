# Copy this file to .env and edit. NEVER commit .env.

# API key required on every /api/* request (X-API-Key header) and on the
# WebSocket (?api_key=...). Generate one with:  openssl rand -hex 24
API_KEY=

# Where the gateway listens for MAVLink coming from mavlink-router.
MAVLINK_ENDPOINT=udpin:0.0.0.0:14551

# Comma-separated CORS origins. "*" is fine while testing; lock it down to
# your ngrok https URL once you know it, e.g. https://abc123.ngrok-free.app
ALLOWED_ORIGINS=*

# Uvicorn bind (used by scripts/start_server.sh).
HOST=0.0.0.0
PORT=8000

# Optional: ngrok authtoken, used by scripts/start_ngrok.sh as an alternative
# to running `ngrok config add-authtoken <token>` once.
#NGROK_AUTHTOKEN=
