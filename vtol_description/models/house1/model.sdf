<?xml version="1.0" ?>
<sdf version="1.9">
  <!-- House 1: the OpenRobotics Fuel mesh re-materialised with a PBR albedo /
       normal map pointing at the model's own texture atlas. The upstream model
       colours the mesh via an Ogre material script, which Gazebo Harmonic
       ignores (leaving the DAE's black fallback) — this restores the texture.
       Mesh loads from the local Fuel cache; textures are bundled locally. -->
  <model name="house1">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry><mesh>
          <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/house 1/3/files/meshes/house_1.dae</uri>
          <scale>1.5 1.5 1.5</scale>
        </mesh></geometry>
      </collision>
      <visual name="visual">
        <geometry><mesh>
          <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/house 1/3/files/meshes/house_1.dae</uri>
          <scale>1.5 1.5 1.5</scale>
        </mesh></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/House_1_Diffuse.png</albedo_map>
              <normal_map>materials/textures/House_1_Normal.png</normal_map>
              <roughness>0.9</roughness>
              <metalness>0.0</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>
</sdf>
