<?xml version="1.0"?>
<model>
  <name>VTOL Fixed-Wing QuadPlane</name>
  <version>1.0</version>
  <sdf version="1.11">model.sdf</sdf>
  <description>
    Custom VTOL with 4 lift propellers and 1 pusher motor.
    All links kinematic (moved via set_pose service).
    Propellers driven by JointController plugins (start static,
    spun up by mavlink_controller.py on ARM command).
  </description>
</model>
