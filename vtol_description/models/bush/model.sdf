<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="bush">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <pose>0 0 0.5 0 0 0</pose>
        <geometry>
          <sphere><radius>0.7</radius></sphere>
        </geometry>
      </collision>

      <!-- Foliage clump: four overlapping textured spheres -->
      <visual name="clump_main">
        <pose>0 0 0.55 0 0 0</pose>
        <geometry><sphere><radius>0.85</radius></sphere></geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.05 0.08 0.05 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/bush_leaves.png</albedo_map>
              <roughness>0.95</roughness>
            </metal>
          </pbr>
        </material>
      </visual>

      <visual name="clump_right">
        <pose>0.55 0.3 0.42 0 0.3 1.1</pose>
        <geometry><sphere><radius>0.6</radius></sphere></geometry>
        <material>
          <diffuse>0.92 1 0.9 1</diffuse>
          <specular>0.05 0.08 0.05 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/bush_leaves.png</albedo_map>
              <roughness>0.95</roughness>
            </metal>
          </pbr>
        </material>
      </visual>

      <visual name="clump_left">
        <pose>-0.5 -0.28 0.4 0.2 0 2.4</pose>
        <geometry><sphere><radius>0.55</radius></sphere></geometry>
        <material>
          <diffuse>0.88 0.97 0.85 1</diffuse>
          <specular>0.05 0.08 0.05 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/bush_leaves.png</albedo_map>
              <roughness>0.95</roughness>
            </metal>
          </pbr>
        </material>
      </visual>

      <visual name="clump_top">
        <pose>0.1 -0.38 0.85 0 0.4 3.6</pose>
        <geometry><sphere><radius>0.45</radius></sphere></geometry>
        <material>
          <diffuse>1 1 0.92 1</diffuse>
          <specular>0.05 0.08 0.05 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/bush_leaves.png</albedo_map>
              <roughness>0.95</roughness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>
</sdf>
