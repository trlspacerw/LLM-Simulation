<?xml version="1.0" ?>
<sdf version="1.9">
  <!-- House 3: OpenRobotics Fuel mesh re-materialised with a PBR albedo map
       from its own texture atlas (the upstream Ogre material script is
       unsupported in Gazebo Harmonic). Mesh loads from the local Fuel cache. -->
  <model name="house3">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry><mesh>
          <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/house 3/3/files/meshes/house_3.dae</uri>
          <scale>1.5 1.5 1.5</scale>
        </mesh></geometry>
      </collision>
      <visual name="visual">
        <geometry><mesh>
          <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/house 3/3/files/meshes/house_3.dae</uri>
          <scale>1.5 1.5 1.5</scale>
        </mesh></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/House_3_Diffuse.png</albedo_map>
              <roughness>0.9</roughness>
              <metalness>0.0</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>
</sdf>
