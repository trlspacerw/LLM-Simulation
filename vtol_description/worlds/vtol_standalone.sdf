<?xml version="1.0" ?>
<!--
  Standalone CLI world — includes the VTOL model directly so that
  gz sim -v4 -r vtol_standalone.sdf works without ros2 launch.
  Use vtol_empty.sdf for the ros2 launch workflow (model spawned separately).
-->
<sdf version="1.9">
  <world name="vtol_world">

    <physics name="1ms" type="ignore">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Core simulation plugins -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Lighting -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
            <specular>0.4 0.4 0.4 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Grass patch -->
    <model name="grass">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>0 0 0.002 0 0 0</pose>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.18 0.42 0.08 1</ambient>
            <diffuse>0.22 0.52 0.10 1</diffuse>
            <specular>0.05 0.12 0.03 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Trees -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
      <name>oak_tree_1</name>
      <pose>8 7 0 0 0 0.4</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
      <name>oak_tree_2</name>
      <pose>-8 9 0 0 0 2.1</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>pine_tree_1</name>
      <pose>11 -3 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>pine_tree_2</name>
      <pose>-10 -5 0 0 0 1.0</pose>
    </include>

    <!-- Cars -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Hatchback</uri>
      <name>hatchback_1</name>
      <pose>7 -2 0 0 0 0.3</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Prius Hybrid</uri>
      <name>prius_1</name>
      <pose>-6 4 0 0 0 -1.2</pose>
    </include>

    <!-- Person -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Walking person</uri>
      <name>person_1</name>
      <pose>3 3 0 0 0 -0.8</pose>
    </include>

    <!-- VTOL model — belly-down at ground level (z=0.3223, Roll=+90°) -->
    <!-- Props start static; mavlink_controller.py spins them up on ARM -->
    <include>
      <uri>model://vtol</uri>
      <name>vtol</name>
      <pose>0 0 0.333 1.5708 0 0</pose>
    </include>

  </world>
</sdf>
