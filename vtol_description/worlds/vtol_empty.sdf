          <material><ambient>0.2 0.48 0.1 1</ambient><diffuse>0.2 0.48 0.1 1</diffuse><specular>0.05 0.05 0.05 1</specular></material>
        </visual>
        <visual name="radial_e">
          <pose>31.000 0.000 0.055 0 0 0.0000</pose>
          <geometry><plane><normal>0 0 1</normal><size>26.0 6.0</size></plane></geometry>
          <material><ambient>0.14 0.14 0.15 1</ambient><diffuse>0.14 0.14 0.15 1</diffuse><specular>0.05 0.05 0.05 1</specular></material>
