<?xml version="1.0"?>
<!--
  URDF for custom VTOL (generated from STL bounding-box data).

  Coordinate convention (matches STL export frame):
    X = lateral  (right wing = +X, left wing = -X)
    Y = vertical (up = +Y)
    Z = longitudinal (nose = +Z, tail = -Z)

  All STL mesh files are in mm; scale="0.001 0.001 0.001" converts to metres.

  Inertial values are rough box/cylinder approximations — update with
  measured component weights and a CAD-computed inertia tensor.

  Joint axis conventions:
    Lift propellers  : spin about Y (vertical axis)
    Aileron          : revolute about X (roll axis, full-span single surface)
    Ruddervators     : revolute about diagonal ±45° X-Y axis (V-tail)
    Pusher motor     : spin about Z (forward axis)
-->
<robot name="vtol">

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!--  BASE LINK — fuselage                                              -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="4.5"/>
      <inertia ixx="1.6084" ixy="0" ixz="0" iyy="1.5301" iyz="0" izz="0.2308"/>
    </inertial>
    <visual>
      <origin xyz="-1.6242 -0.3223 -1.0217" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/fuselage.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="fuselage_mat"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- ─── wing_left ─── -->
  <link name="wing_left">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.2000" ixy="0" ixz="0" iyy="0.0800" iyz="0" izz="0.2000"/>
    </inertial>
    <visual>
      <origin xyz="-0.7752 -0.5821 -1.0387" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/wing_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wing_left_mat"><color rgba="1.0 1.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="wing_left_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wing_left"/>
    <origin xyz="-0.8490 0.2598 0.0170" rpy="0 0 0"/>
  </joint>

  <!-- ─── wing_right ─── -->
  <link name="wing_right">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.2000" ixy="0" ixz="0" iyy="0.0800" iyz="0" izz="0.2000"/>
    </inertial>
    <visual>
      <origin xyz="-2.4734 -0.5849 -1.0301" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/wing_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wing_right_mat"><color rgba="1.0 1.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="wing_right_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wing_right"/>
    <origin xyz="0.8492 0.2626 0.0084" rpy="0 0 0"/>
  </joint>

  <!-- ─── aileron_link ─── -->
  <link name="aileron_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000159" ixy="0" ixz="0" iyy="0.210261" iyz="0" izz="0.210398"/>
    </inertial>
    <visual>
      <origin xyz="-1.6242 -0.5661 -0.9099" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/aileron.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aileron_link_mat"><color rgba="0.4 0.4 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="aileron_link_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="aileron_link"/>
    <origin xyz="0.0000 0.2438 -0.1118" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.44" upper="0.44" effort="10" velocity="10"/>
  </joint>

  <!-- ─── tail_left_link ─── -->
  <link name="tail_left_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0030" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0030"/>
    </inertial>
    <visual>
      <origin xyz="-1.4300 -0.6786 -0.1780" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/tail_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="tail_left_link_mat"><color rgba="0.35 0.35 0.4 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="tail_left_link_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="tail_left_link"/>
    <origin xyz="-0.1942 0.3563 -0.8437" rpy="0 0 0"/>
  </joint>

  <!-- ─── tail_right_link ─── -->
  <link name="tail_right_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0030" ixy="0" ixz="0" iyy="0.0010" iyz="0" izz="0.0030"/>
    </inertial>
    <visual>
      <origin xyz="-1.8184 -0.6786 -0.1780" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/tail_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="tail_right_link_mat"><color rgba="0.35 0.35 0.4 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="tail_right_link_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="tail_right_link"/>
    <origin xyz="0.1942 0.3563 -0.8437" rpy="0 0 0"/>
  </joint>

  <!-- ─── ruddervator_left_link ─── -->
  <link name="ruddervator_left_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0020" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0020"/>
    </inertial>
    <visual>
      <origin xyz="-1.4382 -0.6711 -0.1091" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/ruddervator_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="ruddervator_left_link_mat"><color rgba="0.45 0.45 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="ruddervator_left_link_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="ruddervator_left_link"/>
    <origin xyz="-0.1860 0.3488 -0.9126" rpy="0 0 0"/>
    <axis xyz="0.707 0.707 0"/>
    <limit lower="-0.44" upper="0.44" effort="10" velocity="10"/>
  </joint>

  <!-- ─── ruddervator_right_link ─── -->
  <link name="ruddervator_right_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0020" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0020"/>
    </inertial>
    <visual>
      <origin xyz="-1.8102 -0.6711 -0.1091" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/ruddervator_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="ruddervator_right_link_mat"><color rgba="0.45 0.45 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="ruddervator_right_link_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="ruddervator_right_link"/>
    <origin xyz="0.1860 0.3488 -0.9126" rpy="0 0 0"/>
    <axis xyz="-0.707 0.707 0"/>
    <limit lower="-0.44" upper="0.44" effort="10" velocity="10"/>
  </joint>

  <!-- ═══ Motor 1 ═══ -->
  <link name="motor_1_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000201" ixy="0" ixz="0" iyy="0.000378" iyz="0" izz="0.000201"/>
    </inertial>
    <visual>
      <origin xyz="-1.0142 -0.5574 -1.5395" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/motor_1_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="motor_mat"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_1_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="motor_1_link"/>
    <origin xyz="-0.6100 0.2351 0.5178" rpy="0 0 0"/>
  </joint>

  <link name="prop_1_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001960" ixy="0" ixz="0" iyy="0.001960" iyz="0" izz="0.003920"/>
    </inertial>
    <visual>
      <origin xyz="-1.0142 -0.5636 -1.5395" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/prop_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="prop_mat"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="prop_1_joint" type="continuous"> <!-- CCW -->
    <parent link="motor_1_link"/>
    <child  link="prop_1_link"/>
    <origin xyz="0.0000 0.0062 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ═══ Motor 2 ═══ -->
  <link name="motor_2_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000201" ixy="0" ixz="0" iyy="0.000378" iyz="0" izz="0.000201"/>
    </inertial>
    <visual>
      <origin xyz="-2.2342 -0.5574 -1.5295" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/motor_2_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="motor_mat"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_2_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="motor_2_link"/>
    <origin xyz="0.6100 0.2351 0.5078" rpy="0 0 0"/>
  </joint>

  <link name="prop_2_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001960" ixy="0" ixz="0" iyy="0.001960" iyz="0" izz="0.003920"/>
    </inertial>
    <visual>
      <origin xyz="-2.2342 -0.5636 -1.5295" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/prop_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="prop_mat"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="prop_2_joint" type="continuous">
    <parent link="motor_2_link"/>
    <child  link="prop_2_link"/>
    <origin xyz="0.0000 0.0062 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ═══ Motor 3 ═══ -->
  <link name="motor_3_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000201" ixy="0" ixz="0" iyy="0.000378" iyz="0" izz="0.000201"/>
    </inertial>
    <visual>
      <origin xyz="-2.2342 -0.5574 -0.5295" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/motor_3_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="motor_mat"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_3_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="motor_3_link"/>
    <origin xyz="0.6100 0.2351 -0.4922" rpy="0 0 0"/>
  </joint>

  <link name="prop_3_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001960" ixy="0" ixz="0" iyy="0.001960" iyz="0" izz="0.003920"/>
    </inertial>
    <visual>
      <origin xyz="-2.2342 -0.5636 -0.5295" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/prop_3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="prop_mat"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="prop_3_joint" type="continuous"> <!-- CCW -->
    <parent link="motor_3_link"/>
    <child  link="prop_3_link"/>
    <origin xyz="0.0000 0.0062 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ═══ Motor 4 ═══ -->
  <link name="motor_4_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000201" ixy="0" ixz="0" iyy="0.000378" iyz="0" izz="0.000201"/>
    </inertial>
    <visual>
      <origin xyz="-1.0142 -0.5574 -0.5395" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/motor_4_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="motor_mat"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_4_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="motor_4_link"/>
    <origin xyz="-0.6100 0.2351 -0.4822" rpy="0 0 0"/>
  </joint>

  <link name="prop_4_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001960" ixy="0" ixz="0" iyy="0.001960" iyz="0" izz="0.003920"/>
    </inertial>
    <visual>
      <origin xyz="-1.0142 -0.5636 -0.5395" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/prop_4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="prop_mat"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="prop_4_joint" type="continuous">
    <parent link="motor_4_link"/>
    <child  link="prop_4_link"/>
    <origin xyz="0.0000 0.0062 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ═══ Pusher motor (rear, provides forward thrust along +Z) ═══ -->
  <link name="pusher_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin xyz="-1.6242 -0.4847 -0.0619" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vtol_description/meshes/pusher.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="pusher_mat"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <joint name="pusher_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="pusher_link"/>
    <origin xyz="0.0000 0.1624 -0.9598" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>


  <!-- ── Gazebo: structure links — kinematic + no gravity (moved via set_pose) ── -->
  <gazebo reference="base_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="wing_left"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="wing_right"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="aileron_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="tail_left_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="tail_right_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="ruddervator_left_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="ruddervator_right_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="motor_1_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="motor_2_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="motor_3_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>
  <gazebo reference="motor_4_link"><gravity>0</gravity><kinematic>1</kinematic></gazebo>

  <!-- ── Gazebo: prop/pusher links — dynamic (no gravity), spun by JointController ── -->
  <!-- kinematic=0 so the physics engine can actuate the revolute joints            -->
  <gazebo reference="prop_1_link"><gravity>0</gravity></gazebo>
  <gazebo reference="prop_2_link"><gravity>0</gravity></gazebo>
  <gazebo reference="prop_3_link"><gravity>0</gravity></gazebo>
  <gazebo reference="prop_4_link"><gravity>0</gravity></gazebo>
  <gazebo reference="pusher_link"><gravity>0</gravity></gazebo>

  <!-- ── Gazebo: JointController plugins — props start STATIC (velocity=0) ── -->
  <!-- The mission script publishes to /model/vtol/joint/<name>/0/cmd_vel      -->
  <!-- to spin up on ARM and spin down after landing.                           -->
  <!-- prop_1/3: CCW (+50 rad/s at full speed), prop_2/4: CW (-50 rad/s)       -->
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>prop_1_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>prop_2_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>prop_3_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>prop_4_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>pusher_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
  </gazebo>

</robot>